# ----------------------------
# Python cache & bytecode
# ----------------------------
__pycache__/
*.py[cod]
*$py.class

# ----------------------------
# Virtual environments
# ----------------------------
.venv/
venv/
env/
ENV/
.conda/
.conda_env/
*.egg-info/
.eggs/

# ----------------------------
# Jupyter & IPython
# ----------------------------
.ipynb_checkpoints/
*.ipynb_convert
.profile_default/
ipython_config.py

# ----------------------------
# VSCode / IDE settings
# ----------------------------
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# ----------------------------
# Build / Packaging
# ----------------------------
build/
dist/
*.egg
*.manifest
*.spec

# ----------------------------
# Logs / Outputs
# ----------------------------
*.log
*.out
outputs/
results/
reports/

# ----------------------------
# Data files (large or raw datasets)
# ----------------------------
data/
*.csv
*.tsv
*.dat
*.h5
*.hdf5
*.npz
*.npy
*.mat

# ----------------------------
# Image files (but keep samples)
# ----------------------------
*.tiff
*.tif
*.png
*.jpg
*.jpeg
# EXCEPTION: Keep sample images for documentation
!sample_image_*.png
!sample_image_*.tif
!sample_image_*.jpg

# ----------------------------
# Temporary / Misc
# ----------------------------
.DS_Store
Thumbs.db
*.bak
*.swp
*.tmp

# ----------------------------
# LaTeX outputs
# ----------------------------
*.aux
*.fdb_latexmk
*.fls
*.synctex.gz
*.pdf
# Keep sample reports
!example_report.pdf

# ----------------------------
# Interactive ROI cache (temporary cropped images)
# ----------------------------
outputs/.cache/
